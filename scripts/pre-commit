#!/usr/bin/env bash
# Pre-commit hook: run rustfmt and clippy on staged .rs files
# Fails the commit if either produces errors.
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit

set -e

# Check if there are any staged .rs files
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
if [ -z "$STAGED_RS" ]; then
    exit 0
fi

echo "pre-commit: running rustfmt..."
cargo fmt -- --check
if [ $? -ne 0 ]; then
    echo "rustfmt failed. Run 'cargo fmt' to fix formatting."
    exit 1
fi

echo "pre-commit: running clippy..."
cargo clippy -- -D warnings
if [ $? -ne 0 ]; then
    echo "clippy failed. Fix the warnings above before committing."
    exit 1
fi

echo "pre-commit: all checks passed."
