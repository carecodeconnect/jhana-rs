#!/usr/bin/env bash
# Pre-commit hook: run rustfmt on staged .rs files.
# Clippy is NOT run here — sensevoice-rs has C++ deps that only compile
# on aarch64 (Rock 5A). Clippy runs on the Rock via scripts/rock-build.sh.
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit

set -e

# Check if there are any staged .rs files
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
if [ -z "$STAGED_RS" ]; then
    exit 0
fi

echo "pre-commit: running rustfmt..."
cargo fmt -- --check
if [ $? -ne 0 ]; then
    echo "rustfmt failed. Run 'cargo fmt' to fix formatting."
    exit 1
fi

echo "pre-commit: rustfmt passed. (clippy runs on Rock via rock-build.sh)"
