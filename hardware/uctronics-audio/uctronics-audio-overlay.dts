// Device tree overlay for Uctronics AI in a Box audio codec.
//
// Hardware: custom Useful Sensors "uctronics-codec" — a class-D speaker amp
// (sdmode + 3-bit gain GPIOs) and a MEMS I2S microphone wrapped into one
// ALSA sound card via the rockchip,multicodecs-card framework.
//
// Pairs with the out-of-tree snd-soc-uctronics-codec.ko module
// (see Makefile + snd-soc-uctronics-codec.c in this directory).
//
// Target kernel: Armbian 6.1.115-vendor-rk35xx on Rock 5A.
// See docs/09_AUDIO.md for hardware analysis and reverse-engineering notes.

/dts-v1/;
/plugin/;

/ {
	compatible = "radxa,rock-5a", "rockchip,rk3588s", "rockchip,rk3588";

	fragment@0 {
		target-path = "/";
		__overlay__ {
			audio_codec_0: audio-codec-0 {
				compatible = "uctronics,uctronics-codec";
				sdmode-gpios    = <&gpio3 13 0>; /* GPIO3_B5 — amp enable */
				gainsel_1-gpios = <&gpio3  3 0>; /* GPIO3_A3 — gain MSB */
				gainsel_2-gpios = <&gpio3  5 0>; /* GPIO3_A5 — gain mid */
				gainsel_3-gpios = <&gpio3  2 0>; /* GPIO3_A2 — gain LSB */
				#sound-dai-cells = <0>;
				status = "okay";
			};

			uctronics-sound {
				compatible = "rockchip,multicodecs-card";
				rockchip,card-name = "uctronics-codec";
				rockchip,format = "i2s";
				rockchip,mclk-fs = <256>;
				rockchip,cpu = <&i2s1_8ch>;
				rockchip,codec = <&audio_codec_0>;
				status = "okay";
			};
		};
	};

	// Enable I2S1_8CH (disabled by default in Armbian) and fix its clock mode.
	//
	// Armbian's base DT sets rockchip,trcm-sync-tx-only — in that mode the
	// shared TRCM clock only runs while TX (playback) is active, so a
	// standalone arecord receives no bit-clock on SDI and the mic returns
	// asymmetric DC-offset junk.
	//
	// The Useful Sensors baseline DT instead uses rockchip,clk-trcm = <1>
	// (both directions clocked together). We replicate that here.
	fragment@1 {
		target = <&i2s1_8ch>;
		__overlay__ {
			status = "okay";
			rockchip,playback-channels = <2>;
			rockchip,capture-channels = <2>;

			// rockchip,clk-trcm = <1> forces the TRCM-shared clock to be
			// driven both directions. Without this, Armbian's base DT
			// (which sets rockchip,trcm-sync-tx-only) only clocks RX while
			// TX is active, so standalone arecord captures garbage.
			//
			// We do NOT /delete-property/ rockchip,trcm-sync-tx-only here:
			// an earlier overlay variant that did so prevented boot on this
			// board (u-boot fdt-apply or early kernel rejected it). The
			// rk3588 i2s-tdm driver checks rockchip,clk-trcm first, so adding
			// it should win even if the boolean property is still present.
			rockchip,clk-trcm = <1>;
		};
	};
};
